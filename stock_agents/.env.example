ANTHROPIC_API_KEY=
FMP_API_KEY=                  # https://site.financialmodelingprep.com/developer
TIINGO_API_KEY=               # https://www.tiingo.com/ (optional)
ALPHAVANTAGE_API_KEY=         # https://www.alphavantage.co/ (free tier; optional — earnings transcripts)
EDGAR_USER_AGENT="YourName your.email@example.com"   # SEC requires this
CACHE_DIR=.cache
LOG_LEVEL=INFO
RUN_BUDGET_USD=5.0            # Abort a run if projected cost exceeds this (API backend only)

# v2 Phase 4: notifications (all optional — unset channels are skipped)
PUSHOVER_USER_KEY=
PUSHOVER_APP_TOKEN=
SENDGRID_API_KEY=
ALERT_EMAIL=you@example.com
ALERT_FROM_EMAIL=alerts@example.com
ALERT_CHANNEL=pushover         # pushover | email | both

# v2 Phase 4/5: per-job cost ceilings (metered-API budgets; advisory on Max)
WEEKLY_BUDGET_USD=40
DAILY_POST_EARNINGS_BUDGET_USD=5
SUNDAY_BATCH_BUDGET_USD=25

# Model-calling backend:
#   anthropic   = metered Anthropic API (needs ANTHROPIC_API_KEY with credit)
#   claude_code = drive the `claude` CLI via the Agent SDK on a Claude Max
#                 subscription (usage counts against the plan, not API dollars).
#                 Requires the `claude` CLI logged in to the subscription, and
#                 ANTHROPIC_API_KEY must be UNSET/empty so the CLI uses the
#                 subscription rather than billing the API.
LLM_BACKEND=anthropic
